generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  projects     Project[]
}

model Project {
  id              String      @id @default(cuid())
  userId          String?     // Owner — null for legacy projects
  user            User?       @relation(fields: [userId], references: [id])
  name            String
  agentId         String      // Hamsa agent ID
  hamsaApiKey     String?     // Hamsa API key for this agent
  description     String?
  agentStructure  Json?       // Full agent JSON (workflow nodes, edges, tools)
  flowDefinition  Json?       // Extracted expected node sequence + tool calls
  agentSummary    String?     // LLM-generated plain-text analysis: purpose, scenarios, success criteria
  evalContext     String?     // User-defined evaluation rules injected into every eval for this project
  projectType     ProjectType @default(LIVE)
  historyStartDate DateTime?  // For HISTORY projects: start of date range
  historyEndDate   DateTime?  // For HISTORY projects: end of date range
  criteria        Criterion[]
  runs            Run[]
  analyses        ProjectAnalysis[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum ProjectType {
  LIVE
  HISTORY
  WEBHOOK
}

model Criterion {
  id            String        @id @default(cuid())
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key           String        // e.g. "language_switching", "tool_calls"
  label         String?       // Human-readable name
  type          CriterionType
  expectedValue Json          // Flexible — depends on type
  weight        Float         @default(1.0)
  results       EvalResult[]
  createdAt     DateTime      @default(now())

  @@unique([projectId, key])
}

enum CriterionType {
  DETERMINISTIC
  LLM_JUDGE
  STRUCTURAL
  WORD_ACCURACY
  LATENCY
  FLOW_PROGRESSION
  ACTION_CONSISTENCY
  ACTION_HALLUCINATION
  LAYERED_EVALUATION
}

model Run {
  id             String      @id @default(cuid())
  projectId      String
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  modelUsed      String?     // e.g. "openai/gpt-4o" — optional for history runs
  hamsaCallId    String?     // Returned by Hamsa after call is initiated (jobId)
  conversationId String?     // Hamsa conversation ID (populated for history runs)
  source         RunSource   @default(LIVE)
  callDate       DateTime?   // When the call actually happened (history runs)
  callDuration   Int?        // Call duration in seconds (history runs)
  callStatus     String?     // Hamsa call outcome: COMPLETED, FAILED, NO_ANSWER, etc.
  callOutcome    String?     // jobResponse.outcomeResult.call_outcome (e.g. "interested_followup")
  outcomeResult  Json?       // Full jobResponse.outcomeResult object (summary, variables, language, etc.)
  status         RunStatus   @default(PENDING)
  callLog        Json?       // Raw Hamsa call log array (nodes, tools, timestamps)
  transcript     Json?       // Raw webhook transcript payload
  webhookData    Json?       // Full webhook payload (includes summary, recording URL, etc.)
  overallScore   Float?      // Computed weighted average of all criteria
  evalCost       Float?      // Total OpenAI API cost for this run's evaluations (USD)
  errorLog       String?
  startedAt      DateTime?
  completedAt    DateTime?
  evalResults    EvalResult[]
  wordLabels     WordLabel[]
  createdAt      DateTime    @default(now())

  @@index([projectId])
  @@index([conversationId])
  @@index([status])
  @@index([projectId, source])
  @@index([projectId, status])
  @@unique([projectId, hamsaCallId])
}

enum RunSource {
  LIVE
  HISTORY
  WEBHOOK
}

enum RunStatus {
  PENDING
  RUNNING
  AWAITING_DATA
  EVALUATING
  COMPLETE
  FAILED
}

model EvalResult {
  id            String    @id @default(cuid())
  runId         String
  run           Run       @relation(fields: [runId], references: [id], onDelete: Cascade)
  criterionId   String
  criterion     Criterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  passed        Boolean?
  score         Float?    // 0.0 - 1.0
  detail        String?   // Explanation from LLM judge or diff output
  metadata      Json?     // Extra data (e.g. timing breakdown for LATENCY)
  evaluatedAt   DateTime  @default(now())

  @@unique([runId, criterionId])
}

model WordLabel {
  id            String    @id @default(cuid())
  runId         String
  run           Run       @relation(fields: [runId], references: [id], onDelete: Cascade)
  wordIndex     Int       // Position in flattened transcript word array
  utteranceIndex Int      // Which utterance this word belongs to
  originalWord  String    // What the transcript says
  labelType     LabelType
  correction    String?   // What it should have been
  createdAt     DateTime  @default(now())

  @@unique([runId, wordIndex])
}

model ProjectAnalysis {
  id                String    @id @default(cuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version           Int

  // Which runs were included
  runIds            String[]
  runsIncluded      Int

  // Scope filters that were applied when this version was generated
  dateFilterType    String?   // "CALL_DATE" | "EVAL_DATE" | null (all)
  filterFrom        DateTime?
  filterTo          DateTime?

  // LLM-generated structured analysis
  analysis          Json
  healthScore       Float?

  // Comparison against the immediately previous version
  comparedToVersion Int?
  comparison        Json?

  analysisCost      Float?
  createdAt         DateTime  @default(now())

  @@unique([projectId, version])
  @@index([projectId])
}

enum LabelType {
  WRONG_WORD
  WRONG_LANGUAGE
  WRONG_GENDER
  HALLUCINATED
  LLM_ERROR
  TTS_ERROR
  ASR_ERROR
}
